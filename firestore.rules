rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if request.auth != null;  // Tout utilisateur authentifié peut voir les autres (pour l'équipe)
      allow write: if isAdmin();
      allow update: if request.auth != null && request.auth.uid == uid;
      allow create: if false;
    }

    match /presence/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /appointments/{apptId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /clients/{clientId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /metrics/{uid}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // Règles pour la messagerie
    match /conversations/{convId} {
      // Lecture: tout utilisateur authentifié (filtrage côté client)
      allow read: if request.auth != null;
      // Création si on est participant
      allow create: if request.auth != null &&
                     request.resource.data.participants.hasAny([request.auth.uid]);
      // Mise à jour si on est participant
      allow update: if request.auth != null &&
                     resource.data.participants.hasAny([request.auth.uid]);
    }

    match /conversations/{convId}/messages/{msgId} {
      // Lecture: tout utilisateur authentifié (filtrage côté client par conversation)
      allow read: if request.auth != null;
      // Création si on est connecté (le senderId doit correspondre)
      allow create: if request.auth != null &&
                     request.resource.data.senderId == request.auth.uid;
      // Mise à jour (pour marquer comme lu) - vérifier qu'on est participant
      allow update: if request.auth != null &&
                     get(/databases/$(database)/documents/conversations/$(convId)).data.participants.hasAny([request.auth.uid]);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
